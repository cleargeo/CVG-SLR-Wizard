# =============================================================================
# CVG SLR Wizard — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# Outputs (runtime artifacts)
output/
*.tif
*.geotiff
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.json
!slr_wizard/**/*.json
!sample_config.json
*.pdf
checkpoint_*.json

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log

# Secrets
.env
.env.*
secrets/

# Cache
slr_wizard/cache/*.json
slr_wizard/cache/*.pkl

# Distribution
dist/
*.whl

# Added by commit_all_repos.ps1
.git_disabled/
